{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ],

    "sourceMap": true
  },

  "include": [
    "src/**/*"
  ]
}